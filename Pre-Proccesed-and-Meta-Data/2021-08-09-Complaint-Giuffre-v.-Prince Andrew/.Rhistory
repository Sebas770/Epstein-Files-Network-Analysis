# 2. Clean the text using Regex (Regular Expressions)
text_clean <- raw_text %>%
# Remove page headers (e.g., "--- PAGE 1 ---")
str_remove_all("--- PAGE [0-9]+ ---") %>%
# Replace line breaks (Enters) with a space
str_replace_all("\n", " ") %>%
# Remove extra spaces
str_squish()
